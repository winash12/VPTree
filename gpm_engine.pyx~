cimport cython
from libcpp.vector cimport vector

# 1. Extern the C++ Parallax logic
cdef extern from "Parallax.h" nogil:
    void apply_correction(double& lat, double& lon, double azimuth, 
                          double height_km, double scan_angle_deg)


@cython.boundscheck(False)
@cython.wraparound(False)
def correct_gpm_parallax(double[:, :, :] lats, 
                         double[:, :, :] lons, 
                         double[:] scan_angles,  # 49 rays
                         double[:] scan_azimuths, # nscan azimuths
                         double bin_res_km=0.125): # GPM PR is 125m or 250m
    
    cdef int s, r, b
    cdef int nscan = lats.shape[0]
    cdef int nray = lats.shape[1]
    cdef int nbin = lats.shape[2]
    cdef double height_km
    
    with nogil:
        for s in prange(nscan, schedule='static'):
            for r in range(nray):
                for b in range(nbin):
                    # Height relative to ellipsoid (bin 176 is usually earth)
                    height_km = (nbin - b) * bin_res_km
                    
                    # Apply WGS84 displacement
                    ParallaxEngine.apply_correction(
                        lats[s, r, b], 
                        lons[s, r, b], 
                        scan_azimuths[s], 
                        height_km, 
                        scan_angles[r]
                    )
