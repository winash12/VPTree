#ifndef GPM_VOXEL_INDEX_HPP
#define GPM_VOXEL_INDEX_HPP

#include <vector>
#include <cstdint>
#include <algorithm>
#include <cstring>

namespace gpm {

    // Struct optimized for the VP-Tree (16 bytes, cache-aligned)
    struct alignas(16) Point { 
        double lat; 
        double lon; 
    };

    struct IndexRange { size_t i, j; };

    /** 
     * Block 1: Morton Interleaver (Z-Order Curve)
     */
    inline uint64_t spread(uint32_t x) {
        uint64_t res = x;
        res = (res | (res << 16)) & 0x0000FFFF0000FFFF;
        res = (res | (res << 8))  & 0x00FF00FF00FF00FF;
        res = (res | (res << 4))  & 0x0F0F0F0F0F0F0F0F;
        res = (res | (res << 2))  & 0x3333333333333333;
        res = (res | (res << 1))  & 0x5555555555555555;
        return res;
    }

    inline uint64_t encode_2d(double lat, double lon) {
        // Quantize to 32-bit space
        uint32_t lat_q = static_cast<uint32_t>(((lat + 90.0) / 180.0) * 4294967295.0);
        uint32_t lon_q = static_cast<uint32_t>(((lon + 180.0) / 360.0) * 4294967295.0);
        return (spread(lon_q) << 1) | spread(lat_q);
    }

    /**
     * Block 2: Branch-Free Binary Search
     * Replaces Eytzinger search for better range-scan locality.
     */
    inline size_t branchfree_search(const std::vector<uint64_t>& data, uint64_t key) {
        size_t n = data.size();
        if (n == 0) return 0;
        const uint64_t* base = data.data();
        while (n > 1) {
            size_t half = n / 2;
            base = (base[half] < key) ? base + half : base;
            n -= half;
        }
        return (base < key) ? (base - data.data() + 1) : (base - data.data());
    }

    class VoxelIndex {
    private:
        std::vector<uint64_t> geohashes; // Sorted keys
        std::vector<Point>    coords;    // Parallel Lat/Lon
        std::vector<float>    dbz;       // Parallel Reflectivity

    public:
        // Constructor: Expects data pre-sorted by geohash
        VoxelIndex(std::vector<uint64_t> h, std::vector<Point> c, std::vector<float> v) 
            : geohashes(std::move(h)), coords(std::move(c)), dbz(std::move(v)) {}

        inline IndexRange get_range(uint64_t low, uint64_t high) const {
            return { branchfree_search(geohashes, low), 
                     branchfree_search(geohashes, high + 1) };
        }

        /**
         * The Bridge: Pulls candidate points into contiguous memory.
         * This makes the subsequent VP-Tree construction much faster.
         */
        void collect_candidates(const std::vector<IndexRange>& ranges, 
                                std::vector<Point>& out_coords,
                                std::vector<float>& out_dbz) const {
            size_t total = 0;
            for (const auto& r : ranges) if (r.i < r.j) total += (r.j - r.i);
            
            size_t start = out_coords.size();
            out_coords.resize(start + total);
            out_dbz.resize(start + total);

            Point* dst_c = &out_coords[start];
            float* dst_v = &out_dbz[start];

            for (const auto& r : ranges) {
                if (r.i >= r.j) continue;
                size_t count = r.j - r.i;
                std::memcpy(dst_c, &coords[r.i], count * sizeof(Point));
                std::memcpy(dst_v, &dbz[r.i], count * sizeof(float));
                dst_c += count;
                dst_v += count;
            }
        }

        /**
         * Dateline-Safe Range Logic
         * Handles GPM passes crossing the ±180° meridian.
         */
        void get_safe_ranges(double lat_min, double lat_max, 
                             double lon_min, double lon_max,
                             std::vector<IndexRange>& results) const {
            results.clear();
            if (lon_max > 180.0) {
                results.push_back(get_range(encode_2d(lat_min, lon_min), encode_2d(lat_max, 180.0)));
                results.push_back(get_range(encode_2d(lat_min, -180.0), encode_2d(lat_max, lon_max - 360.0)));
            } else if (lon_min < -180.0) {
                results.push_back(get_range(encode_2d(lat_min, -180.0), encode_2d(lat_max, lon_max)));
                results.push_back(get_range(encode_2d(lat_min, lon_min + 360.0), encode_2d(lat_max, 180.0)));
            } else {
                results.push_back(get_range(encode_2d(lat_min, lon_min), encode_2d(lat_max, lon_max)));
            }
        }
    };
}
#endif
