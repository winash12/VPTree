#ifndef PARALLAX_H
#define PARALLAX_H

#include <GeographicLib/Geodesic.hpp>
#include <cmath>
#include <algorithm>

/**
 * GPM PR Parallax Engine (WGS84 Ellipsoid Version)
 * Optimized for the Optiplex 7050 (i7-7700)
 */
class ParallaxEngine {
private:
  // Reference to the global WGS84 ellipsoid (Thread-safe)
  const GeographicLib::Geodesic& geod;
  
public:
  ParallaxEngine() : geod(GeographicLib::Geodesic::WGS84()) {}
  
  /**
   * Corrects a single GPM Bin using the Direct Geodesic Problem.
   * @param lat        Input/Output Latitude (WGS84)
   * @param lon        Input/Output Longitude (WGS84)
   * @param sc_heading The spacecraft heading (scOrientation) in degrees
   * @param bin_height Height of the bin above ellipsoid in km
   * @param incidence  Incidence angle from Nadir (degrees)
   * @param ray_index  The ray index (0-48). GPM Nadir is 24.
   */
  inline void apply_bin_correction(double& lat, double& lon, 
                                   double sc_heading, 
                                   double bin_height, 
                                   double incidence, 
                                   int ray_index) const {
    
    // 1. Skip Nadir (Ray 24) or No-Data height
    if (ray_index == 24 || bin_height <= 0.0) return;
    
    // 2. Determine Shift Direction (90 deg left/right of heading)
    // Ray 0-23 (Left), Ray 25-48 (Right)
    double shift_azimuth;
    if (ray_index < 24) {
      shift_azimuth = sc_heading - 90.0; // Left Orbit
    } else {
      shift_azimuth = sc_heading + 90.0; // Right Orbit
    }
    
    // 3. Calculate Shift Distance: H * tan(theta)
    // bin_height is in km, we need meters for Geodetic math
    double shift_meters = (bin_height * 1000.0) * std::tan(incidence * M_PI / 180.0);
    
    // 4. Perform Direct Geodesic (The "Karney" Move)
    // This is 100x more accurate than MATLAB's spherical 'reckon'
    double out_lat, out_lon;
    geod.Direct(lat, lon, shift_azimuth, shift_meters, out_lat, out_lon);
    
    // 5. Mutate in-place (No memory allocation)
    lat = out_lat;
    lon = out_lon;
  }
};

#endif
